{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/pageourteam", "destination": "/pageourteam/index.html" },
    { "source": "/pageproblemidentification", "destination": "/pageproblemidentification/index.html" },
    { "source": "/pageengineeringdesign", "destination": "/pageengineeringdesign/index.html" },
    { "source": "/pagedesignrequirement", "destination": "/pagedesignrequirement/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|png|jpg|jpeg|webp|avif|svg|ico|woff2|woff)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
